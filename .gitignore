# pyenv
#   For a library or binary, you may want to ignore these files
#   but for a dedicated project, it's common to keep them.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you choose not to, then uncomment the following line:
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   Poetry's documentation suggests including poetry.lock in VCS.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# pdm.lock
#   pdm focuses on project-specific environments, so the .pdm-python file should be ignored.
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

